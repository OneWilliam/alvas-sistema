{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["bun-types"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@alvas/api/*": ["apps/api/src/*"],
      "@alvas/web/*": ["apps/web/src/*"],
    },
  },
  "include": ["apps/**/*.ts"],
  "exclude": ["node_modules", "dist", "out", ".wrangler", "coverage"],
}
