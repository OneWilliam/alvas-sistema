{
  "name": "alvas-sistema",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd apps/api dev",
    "dev:web": "bun --cwd apps/web dev",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p packages/shared-types/tsconfig.json && tsc --noEmit -p packages/shared-utils/tsconfig.json",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "bun-types": "latest",
    "eslint": "^10.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.85.0"
  }
}
