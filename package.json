{
  "name": "alvas-sistema",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd apps/api dev",
    "dev:web": "bun --cwd apps/web dev",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate:local": "bun --cwd apps/api wrangler d1 migrations apply alvas-dev --local",
    "db:migrate:remote": "bun --cwd apps/api wrangler d1 migrations apply alvas-main --remote",
    "test": "bun test",
    "test:bdd": "bun --cwd apps/api test:bdd",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "prepare": "husky",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "bun-types": "latest",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.85.0"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
